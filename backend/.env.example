# Aiven MySQL
DATABASE_URL=mysql://user:password@host:port/dbname

# Groq API Key (free from https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Server port (local dev only)
PORT=3001

# Frontend URL for CORS (comma-separated for multiple)
FRONTEND_URL=http://localhost:5173

# Aiven CA certificate (required on Vercel since certs/ca.pem is not deployed)
# Paste the full contents of ca.pem as a single-line string
CA_CERT=
